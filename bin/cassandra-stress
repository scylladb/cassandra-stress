find_all_jars() {
  find "$1" -name '*.jar' -print 2>/dev/null | paste -sd ":" -
}

DESC="Cassandra Stress"

if [ -n "$JAVA_HOME" ]; then
  if [ -x "$JAVA_HOME/bin/java" ]; then
    JAVA="$JAVA_HOME/bin/java"
  fi
else
  JAVA=java
fi

if [ -z "$JAVA" ]; then
  echo Unable to find java executable. Check JAVA_HOME and PATH environment variables. >&2
  exit 1
fi

java_ver_output=$("${JAVA:-java}" -version 2>&1)
jvmver=$(echo "$java_ver_output" | grep '[openjdk|java] version' | awk -F'"' 'NR==1 {print $2}' | cut -d. -f1)
if [ "$jvmver" -lt "11" ]; then
  echo "Cassandra-Stress requires Java 11 (or newer)."
  exit 1
fi

if [ -d "/usr/share/cassandra-stress" ]; then
  CASSANDRA_STRESS_HOME="/usr/share/cassandra-stress"
else
  CASSANDRA_STRESS_HOME="$(realpath "$(dirname "$0")")"
fi

if [ -d "/etc/cassandra-stress" ]; then
  CASSANDRA_STRESS_CONFIG="/etc/cassandra-stress"
else
  while [ "$CASSANDRA_STRESS_HOME" != "/" ]; do
    if [ -d "$CASSANDRA_STRESS_HOME/conf" ]; then
      break
    fi
    CASSANDRA_STRESS_HOME="$(dirname "$CASSANDRA_STRESS_HOME")"
  done

  if [ "$CASSANDRA_STRESS_HOME" = "/" ]; then
    echo "Error: 'conf' directory not found in any parent directory."
    exit 1
  fi

  if [ "$CASSANDRA_STRESS_CONFIG" = "" ]; then
    CASSANDRA_STRESS_CONFIG="$CASSANDRA_STRESS_HOME/conf"
  fi
fi

if [ -d "$CASSANDRA_STRESS_HOME/build" ]; then
  classes="$CASSANDRA_STRESS_HOME/build/classes"
  CLASSPATH="$classes/thrift:$classes/main:$(find_all_jars "$CASSANDRA_STRESS_HOME/build/lib")"

  CLASSPATH="${CLASSPATH#:}"
fi

if [ "$CASSANDRA_STRESS_STORAGE_DIR" = "" ]; then
  CASSANDRA_STRESS_STORAGE_DIR="$CASSANDRA_STRESS_HOME/data"
fi

CONFIG_FILE_REALPATH=$(realpath "$CASSANDRA_STRESS_CONFIG/cassandra.yaml")

if [ -f "$CASSANDRA_STRESS_CONFIG/scylla.yaml" ]; then
  CONFIG_FILE_REALPATH=$(realpath "$CASSANDRA_STRESS_CONFIG/scylla.yaml")
fi

CLASSPATH="${CLASSPATH}:$(find_all_jars "$CASSANDRA_STRESS_HOME/lib")"
CLASSPATH="${CLASSPATH#:}"

if [ "$CLASSPATH" = "" ]; then
  echo "You must set the CLASSPATH var" >&2
  exit 1
fi

# ============================================================================
# JVM Performance Tuning
#
# All flags below have reasonable defaults but can be overridden via
# environment variables. Set any variable to "false" to disable its flag,
# or provide a custom value where applicable.
# ============================================================================

# --- Heap Configuration ---
# Override: CASSANDRA_STRESS_HEAP_SIZE (default: 8g)
CASSANDRA_STRESS_HEAP_SIZE="${CASSANDRA_STRESS_HEAP_SIZE:-8g}"

# --- Thread Stack Size ---
# Override: CASSANDRA_STRESS_STACK_SIZE (default: 512k)
# Reduced from 1MB default — stress tools spawn many threads; saves memory and TLB pressure.
CASSANDRA_STRESS_STACK_SIZE="${CASSANDRA_STRESS_STACK_SIZE:-512k}"

# --- Tiered Compilation ---
# Override: CASSANDRA_STRESS_TIERED_COMPILATION (default: false)
# Disabled by default — skips C1, compiles directly with C2 for peak throughput.
# Stress tools run long enough that warmup time is irrelevant.
CASSANDRA_STRESS_TIERED_COMPILATION="${CASSANDRA_STRESS_TIERED_COMPILATION:-false}"

# --- NUMA Support ---
# Override: CASSANDRA_STRESS_NUMA (default: true)
# ZGC is NUMA-aware. Ensures NUMA-local allocations on multi-socket machines.
CASSANDRA_STRESS_NUMA="${CASSANDRA_STRESS_NUMA:-true}"

# --- AlwaysPreTouch ---
# Override: CASSANDRA_STRESS_PRE_TOUCH (default: true)
# Pre-faults heap pages at startup — eliminates page-fault latency during operation.
CASSANDRA_STRESS_PRE_TOUCH="${CASSANDRA_STRESS_PRE_TOUCH:-true}"

# --- ZGC Uncommit ---
# Override: CASSANDRA_STRESS_ZGC_UNCOMMIT (default: false)
# Disabled by default — prevents ZGC from returning memory to OS which causes
# recommit/page-fault latency spikes under sustained load.
CASSANDRA_STRESS_ZGC_UNCOMMIT="${CASSANDRA_STRESS_ZGC_UNCOMMIT:-false}"

# --- Optimize String Concatenation ---
# Override: CASSANDRA_STRESS_OPTIMIZE_STRING_CONCAT (default: true)
# C2 compiler optimizes StringBuilder chains — fewer allocations in request hot paths.
CASSANDRA_STRESS_OPTIMIZE_STRING_CONCAT="${CASSANDRA_STRESS_OPTIMIZE_STRING_CONCAT:-true}"

# --- Parallel Reference Processing ---
# Override: CASSANDRA_STRESS_PARALLEL_REF_PROC (default: true)
# Parallel reference processing during GC. Helps with WeakReferences/SoftReferences
# in driver connection pools.
CASSANDRA_STRESS_PARALLEL_REF_PROC="${CASSANDRA_STRESS_PARALLEL_REF_PROC:-true}"

# --- AutoBox Cache Max ---
# Override: CASSANDRA_STRESS_AUTOBOX_CACHE_MAX (default: 20000)
# Extends Integer cache beyond [-128,127] — eliminates boxing allocations in hot counter paths.
CASSANDRA_STRESS_AUTOBOX_CACHE_MAX="${CASSANDRA_STRESS_AUTOBOX_CACHE_MAX:-20000}"

# JPMS settings (Java 11+)
JVM_OPTS="$JVM_OPTS \
  -Djdk.attach.allowAttachSelf=true \
  --add-exports java.base/jdk.internal.misc=ALL-UNNAMED \
  --add-opens java.base/jdk.internal.module=ALL-UNNAMED \
  --add-opens=java.base/java.lang=ALL-UNNAMED \
  --add-opens=java.base/java.util=ALL-UNNAMED \
  --add-opens=java.base/java.io=ALL-UNNAMED \
  --add-opens java.base/java.net=ALL-UNNAMED \
  --add-opens java.base/sun.nio.ch=ALL-UNNAMED \
  --add-exports java.base/jdk.internal.ref=ALL-UNNAMED \
  --add-exports java.base/sun.nio.ch=ALL-UNNAMED \
  --add-exports java.management.rmi/com.sun.jmx.remote.internal.rmi=ALL-UNNAMED \
  --add-exports java.rmi/sun.rmi.registry=ALL-UNNAMED \
  --add-exports java.rmi/sun.rmi.server=ALL-UNNAMED \
  --add-opens jdk.management/com.sun.management.internal=ALL-UNNAMED \
"

# Heap sizing (equal min/max prevents resize overhead)
JVM_OPTS="$JVM_OPTS -Xms${CASSANDRA_STRESS_HEAP_SIZE} -Xmx${CASSANDRA_STRESS_HEAP_SIZE}"

# Thread stack size
JVM_OPTS="$JVM_OPTS -Xss${CASSANDRA_STRESS_STACK_SIZE}"

# Tiered compilation
if [ "$CASSANDRA_STRESS_TIERED_COMPILATION" = "false" ]; then
  JVM_OPTS="$JVM_OPTS -XX:-TieredCompilation"
fi

# String concatenation optimization
if [ "$CASSANDRA_STRESS_OPTIMIZE_STRING_CONCAT" = "true" ]; then
  JVM_OPTS="$JVM_OPTS -XX:+OptimizeStringConcat"
fi

# Parallel reference processing
if [ "$CASSANDRA_STRESS_PARALLEL_REF_PROC" = "true" ]; then
  JVM_OPTS="$JVM_OPTS -XX:+ParallelRefProcEnabled"
fi

# AutoBox cache extension
JVM_OPTS="$JVM_OPTS -XX:AutoBoxCacheMax=${CASSANDRA_STRESS_AUTOBOX_CACHE_MAX}"

# ZGC with generational mode for Java 21+ (sub-ms pauses, stable latency)
if [ "$jvmver" -gt "20" ]; then
  JVM_OPTS="$JVM_OPTS -XX:+UseZGC -XX:+ZGenerational"

  if [ "$CASSANDRA_STRESS_PRE_TOUCH" = "true" ]; then
    JVM_OPTS="$JVM_OPTS -XX:+AlwaysPreTouch"
  fi

  if [ "$CASSANDRA_STRESS_ZGC_UNCOMMIT" = "false" ]; then
    JVM_OPTS="$JVM_OPTS -XX:-ZUncommit"
  fi

  if [ "$CASSANDRA_STRESS_NUMA" = "true" ]; then
    JVM_OPTS="$JVM_OPTS -XX:+UseNUMA"
  fi
fi

case "$1" in
usage)
  echo "Cassandra-Stress Server Usage: $0 start|stop|status [-h <host>]"
  echo "Cassandra-Stress Usage: $0 [options]"
  exit 1
  ;;
start)
  echo "Starting $DESC: "
  # shellcheck disable=SC2086,SC2068
  "$JAVA" $JVM_OPTS \
    -server \
    -cp "$CLASSPATH" \
    -Dcassandra.storagedir="$CASSANDRA_STRESS_STORAGE_DIR" \
    -Dcassandra.logdir="$CASSANDRA_STRESS_STORAGE_DIR/logs" \
    -Dlogback.configurationFile="$CASSANDRA_STRESS_CONFIG/logback.xml" \
    org.apache.cassandra.stress.StressServer \
    $@ 1>$CASSANDRA_STRESS_STORAGE_DIR/logs/stressd.out.log 2>$CASSANDRA_STRESS_STORAGE_DIR/logs/stressd.err.log &
  echo $! >./stressd.pid
  echo "done."
  ;;

stop)
  PID="$(cat ./stressd.pid 2>/dev/null)"

  if [ "$PID" = "" ]; then
    echo "$DESC is not running."
  else
    kill -9 "$PID"
    rm ./stressd.pid
    echo "$DESC is stopped."
  fi
  ;;

status)
  PID="$(cat ./stressd.pid 2>/dev/null)"

  if [ "$PID" = "" ]; then
    echo "$DESC is not running."
  else
    echo "$DESC is running with pid $PID."
  fi
  ;;

*)
  # shellcheck disable=SC2086,SC2068
  "$JAVA" $JVM_OPTS \
    -cp $CLASSPATH \
    -Dcassandra.config="file://$CONFIG_FILE_REALPATH" \
    -Dcassandra.storagedir="$CASSANDRA_STRESS_STORAGE_DIR" \
    -Dcassandra.logdir="$CASSANDRA_STRESS_STORAGE_DIR/logs" \
    -Dlogback.configurationFile="$CASSANDRA_STRESS_CONFIG/logback.xml" \
    org.apache.cassandra.stress.Stress $@
  ;;
esac
